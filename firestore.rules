rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'reocleanproperties@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Products
    match /products/{productId} {
      function isValidProduct(data) {
        return data.get('name', '') is string && 
               data.get('price', 0) is number && 
               data.get('category', '') is string &&
               data.get('image', '') is string && 
               data.image.size() <= 1048576 &&
               data.get('images', []) is list &&
               (data.get('unit', 'pcs') in ['gm', 'kg', 'ml', 'l', 'pcs']) &&
               (data.get('size', 1) is number);
      }

      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && 
                    isValidProduct(incoming()) && 
                    incoming().get('createdAt', existing().get('createdAt', request.time)) == existing().get('createdAt', request.time);
      allow delete: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      function isValidCategory(data) {
        return data.name is string && data.name.size() > 0 &&
               data.icon is string;
      }

      allow read: if true;
      allow create: if isAdmin() && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.userId == request.auth.uid &&
               data.items is list && data.items.size() > 0 &&
               data.total is number && data.total >= 0 &&
               data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
               data.customer is map &&
               data.customer.name is string &&
               data.customer.phone is string &&
               data.customer.address is string &&
               data.createdAt == request.time;
      }

      allow create: if isSignedIn() && isValidOrder(incoming());
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                    incoming().status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
                    incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    // Admin List
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable through Firebase Console or by initial admin if logic added
    }
  }
}
