rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email_verified == true && request.auth.token.email == 'reocleanproperties@gmail.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Products
    match /products/{productId} {
      function isValidProduct(data) {
        return data.get('name', '') is string && data.name.size() > 0 &&
               data.get('price', 0) is number && 
               data.get('category', '') is string &&
               data.get('image', '') is string && 
               data.get('images', []) is list &&
               data.get('unit', '') is string &&
               data.get('moq', 1) is number &&
               data.get('step', 1) is number;
      }

      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && 
                    isValidProduct(incoming()) && 
                    incoming().get('createdAt', existing().get('createdAt', request.time)) == existing().get('createdAt', request.time);
      allow delete: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      function isValidCategory(data) {
        return data.name is string && data.name.size() > 0 &&
               data.icon is string;
      }

      allow read: if true;
      allow create: if isAdmin() && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      function isValidOrder(data) {
        let authCheck = (!data.get('userId', null) || (isSignedIn() && data.userId == request.auth.uid));
        
        return authCheck &&
               data.get('items', []) is list && data.items.size() > 0 &&
               data.get('total', 0) is number && data.total >= 0 &&
               data.get('status', 'pending') in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
               data.get('customer', {}) is map &&
               data.customer.get('name', '') is string && data.customer.name.size() > 0 &&
               data.customer.get('phone', '') is string && data.customer.phone.size() > 0 &&
               data.customer.get('address', '') is string && data.customer.address.size() > 0 &&
               data.get('createdAt', request.time) == request.time;
      }

      allow create: if isValidOrder(incoming());
      allow get: if true; // Allow anyone with an order ID to track it
      allow list: if isAdmin();
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                    incoming().get('status', '') in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
                    incoming().get('updatedAt', request.time) == request.time;
      allow delete: if isAdmin();
    }

    // Admin List
    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if false; 
    }

    // Users
    match /users/{userId} {
      function isValidUser(data) {
        return data.get('email', '') is string && data.get('email', '').size() > 0 &&
               data.get('role', 'viewer') in ['admin', 'editor', 'viewer'] &&
               data.get('points', 0) is number &&
               data.get('tier', 'Bronze') in ['Bronze', 'Silver', 'Gold', 'Platinum'] &&
               data.get('lifetimeSpent', 0) is number;
      }
      
      function isOwner(uid) {
        return isSignedIn() && request.auth.uid == uid;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && incoming().get('createdAt', request.time) == request.time;
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming()) && 
                    // Prevent non-admins from changing their role
                    (isAdmin() || incoming().get('role', 'viewer') == existing().get('role', 'viewer'));
      allow delete: if isAdmin();
    }

    // Manual Invoices
    match /manualInvoices/{invoiceId} {
      function isValidManualInvoice(data) {
        return data.get('invoiceNo', '') is string && data.invoiceNo.size() > 0 &&
               data.get('customer', {}) is map &&
               data.get('items', []) is list &&
               data.get('total', 0) is number;
      }
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidManualInvoice(incoming()) && incoming().get('createdAt', request.time) == request.time;
      allow update: if isAdmin() && isValidManualInvoice(incoming());
      allow delete: if isAdmin();
    }

    // Public Activity (for Social Proof)
    match /public_activity/{activityId} {
      allow read: if true;
      allow create: if isSignedIn() || true; // Allow system-triggered (anonymous checkout also triggers this)
    }

    // Customer Gallery
    match /customerGallery/{galleryId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Sliders
    match /sliders/{sliderId} {
      function isValidSlider(data) {
        return data.get('imageUrl', '') is string && data.get('imageUrl', '').size() > 0 &&
               data.get('title', '') is string &&
               data.get('description', '') is string &&
               data.get('link', '') is string &&
               data.get('order', 0) is number;
      }
      allow read: if true;
      allow create: if isAdmin() && isValidSlider(incoming());
      allow update: if isAdmin() && isValidSlider(incoming());
      allow delete: if isAdmin();
    }

    // Producers
    match /producers/{producerId} {
      function isValidProducer(data) {
        return data.get('name', '') is string && data.get('name', '').size() > 0 && data.get('name', '').size() <= 200 &&
               data.get('role', '') is string && data.get('role', '').size() > 0 && data.get('role', '').size() <= 200 &&
               data.get('img', '') is string && data.get('img', '').size() > 0 && data.get('img', '').size() <= 1000000 &&
               data.get('story', '') is string && data.get('story', '').size() > 0 && data.get('story', '').size() <= 10000 &&
               data.get('order', 0) is number;
      }
      allow read: if true;
      allow create: if isAdmin() && isValidProducer(incoming());
      allow update: if isAdmin() && isValidProducer(incoming());
      allow delete: if isAdmin();
    }

    // Press Coverages
    match /press/{pressId} {
      function isValidPress(data) {
        return data.get('source', '') is string && data.get('source', '').size() > 0 && data.get('source', '').size() <= 200 &&
               data.get('title', '') is string && data.get('title', '').size() > 0 && data.get('title', '').size() <= 400 &&
               data.get('excerpt', '') is string && data.get('excerpt', '').size() > 0 && data.get('excerpt', '').size() <= 4000 &&
               data.get('img', '') is string && data.get('img', '').size() > 0 && data.get('img', '').size() <= 1000000 &&
               data.get('link', '') is string && data.get('link', '').size() <= 2000 &&
               data.get('date', '') is string && data.get('date', '').size() <= 100 &&
               data.get('order', 0) is number;
      }
      allow read: if true;
      allow create: if isAdmin() && isValidPress(incoming());
      allow update: if isAdmin() && isValidPress(incoming());
      allow delete: if isAdmin();
    }

    // Site Settings
    match /settings/{settingId} {
      function isValidSetting(data) {
        return data.get('logoUrl', '') is string && data.get('logoUrl', '').size() > 0 && data.get('logoUrl', '').size() <= 1500000;
      }
      allow read: if true;
      allow create, update: if isAdmin() && isValidSetting(incoming());
      allow delete: if isAdmin();
    }
  }
}
