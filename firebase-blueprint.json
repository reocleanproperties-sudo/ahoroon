{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "E-commerce product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "isFlashSale": { "type": "boolean" },
        "discount": { "type": "number" },
        "unit": { "type": "string" },
        "moq": { "type": "number" },
        "step": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "image", "category", "description"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "icon"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "status", "customer", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Application user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor", "viewer"] },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "points": { "type": "number" },
        "tier": { "type": "string", "enum": ["Bronze", "Silver", "Gold", "Platinum"] },
        "lifetimeSpent": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "CustomerGallery": {
      "title": "Customer Gallery",
      "description": "User shared photos and videos",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "url": { "type": "string" },
        "thumbnail": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "comment": { "type": "string" },
        "likes": { "type": "number" },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "url", "createdAt"]
    },
    "ManualInvoice": {
      "title": "Manual Invoice",
      "description": "Manually created invoice",
      "type": "object",
      "properties": {
        "invoiceNo": { "type": "string" },
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "unit": { "type": "string" }
            }
          }
        },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceNo", "customer", "items", "total", "createdAt"]
    },
    "Producer": {
      "title": "Producer",
      "description": "Producer profile card",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "img": { "type": "string" },
        "story": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "role", "img", "story", "order"]
    },
    "PressCoverage": {
      "title": "PressCoverage",
      "description": "Newspaper or media mention card",
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "img": { "type": "string" },
        "link": { "type": "string" },
        "date": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["source", "title", "excerpt", "img", "link", "date", "order"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Store site settings like custom logo",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" }
      },
      "required": ["logoUrl"]
    }
  },
  "firestore": {
    "settings/{settingId}": {
      "schema": "Setting",
      "description": "Collection of store configuration settings"
    },
    "press/{pressId}": {
      "schema": "PressCoverage",
      "description": "Collection of newspaper coverage"
    },
    "producers/{producerId}": {
      "schema": "Producer",
      "description": "Collection of producers shown on the home page"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of categories"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of application users"
    },
    "manualInvoices/{invoiceId}": {
      "schema": "ManualInvoice",
      "description": "Collection of manual invoices"
    },
    "customerGallery/{galleryId}": {
      "schema": "CustomerGallery",
      "description": "Collection of user shared media"
    },
    "admins/{adminId}": {
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string" }
        }
      },
      "description": "Admin users list"
    }
  }
}
