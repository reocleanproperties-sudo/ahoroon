{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "E-commerce product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "isFlashSale": { "type": "boolean" },
        "discount": { "type": "number" },
        "unit": { "type": "string" },
        "moq": { "type": "number" },
        "step": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "image", "category", "description"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "icon"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "status", "customer", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Application user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor", "viewer"] },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "ManualInvoice": {
      "title": "Manual Invoice",
      "description": "Manually created invoice",
      "type": "object",
      "properties": {
        "invoiceNo": { "type": "string" },
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "unit": { "type": "string" }
            }
          }
        },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceNo", "customer", "items", "total", "createdAt"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of categories"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of application users"
    },
    "manualInvoices/{invoiceId}": {
      "schema": "ManualInvoice",
      "description": "Collection of manual invoices"
    },
    "admins/{adminId}": {
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string" }
        }
      },
      "description": "Admin users list"
    }
  }
}
